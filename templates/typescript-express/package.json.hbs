{
  "name": "{{projectSlug}}",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "test": "node --import tsx --test tests/**/*.test.ts",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "express": "^{{frameworkVersion}}"{{#if orm}},
    "@prisma/client": "^5.20.0"{{/if}}{{#if auth}},
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2"{{/if}}{{#if validation}},
    "class-validator": "^0.14.1",
    "joi": "^17.13.3",
    "zod": "^3.23.8"{{/if}}
  },
  "devDependencies": {
    {{#if auth}}"@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    {{/if}}
    "@types/express": "^{{expressTypesVersion}}",
    "@types/node": "^{{nodeTypesVersion}}",
    "eslint": "^9.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.2.5",
    "tsx": "^{{tsxVersion}}",
    "typescript": "^{{languageVersion}}"{{#if orm}},
    "prisma": "^5.20.0"{{/if}}
  }
}
