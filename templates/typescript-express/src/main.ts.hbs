import express from "express";
import { loadEnvironment } from "./shared/config/environment.js";
import { logger } from "./shared/logger.js";
import { errorHandler, notFoundHandler } from "./presentation/middleware/errorHandler.js";
import { requestLogger } from "./presentation/middleware/requestLogger.js";
import { createOpenApiRouter } from "./presentation/routes/openApiRoutes.js";
{{#if auth}}
import { createAuthRouter } from "./presentation/routes/authRoutes.js";
{{/if}}
{{#each entities}}
import { create{{className}}Router } from "./presentation/routes/{{camelName}}Routes.js";
{{/each}}

const app = express();
const environment = loadEnvironment();

app.use(express.json());
app.use(requestLogger);

app.get("/health", (_request, response) => {
  response.json({ status: "ok", service: "{{projectSlug}}" });
});

app.use(createOpenApiRouter());
{{#if auth}}
app.use("/auth", createAuthRouter());
{{/if}}
{{#each entities}}
app.use("/{{routeName}}", create{{className}}Router());
{{/each}}

app.use(notFoundHandler);
app.use(errorHandler);

app.listen(environment.port, () => {
  logger.info("server_started", { service: "{{projectName}}", port: environment.port });
});
