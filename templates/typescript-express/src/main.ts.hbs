import express from "express";
{{#each entities}}
import { create{{className}}Router } from "./presentation/controllers/{{camelName}}Controller.js";
{{/each}}

const app = express();
const port = Number(process.env.PORT ?? 3000);

app.use(express.json());

app.get("/health", (_request, response) => {
  response.json({ status: "ok", service: "{{projectSlug}}" });
});

{{#each entities}}
app.use("/{{routeName}}", create{{className}}Router());
{{/each}}

app.listen(port, () => {
  console.log(`{{projectName}} listening on port ${port}`);
});
