package main

import (
	"net/http"

	"github.com/gin-gonic/gin"
{{#if hasEntities}}
	"{{moduleName}}/internal/handler"
{{/if}}
)

func main() {
	router := gin.Default()

	router.GET("/health", func(context *gin.Context) {
		context.JSON(http.StatusOK, gin.H{
			"status":  "ok",
			"service": "{{projectSlug}}",
		})
	})
{{#each entities}}
	handler.Register{{className}}Routes(router)
{{/each}}

	if err := router.Run(); err != nil {
		panic(err)
	}
}
