{
  "name": "{{projectSlug}}",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "test": "node --import tsx --test test/**/*.ts",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@nestjs/common": "^{{frameworkVersion}}",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^{{frameworkVersion}}",
    "@nestjs/platform-express": "^{{frameworkVersion}}",
    "@nestjs/swagger": "^7.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "reflect-metadata": "^{{reflectMetadataVersion}}",
    "rxjs": "^{{rxjsVersion}}"
  },
  "devDependencies": {
    "@nestjs/cli": "^{{frameworkVersion}}",
    "@types/node": "^{{nodeTypesVersion}}",
    "eslint": "^9.0.0",
    "prettier": "^3.2.5",
    "tsx": "^4.7.1",
    "typescript": "^{{languageVersion}}"
  }
}
