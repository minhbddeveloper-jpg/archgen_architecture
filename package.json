{
  "name": "arxgen",
  "version": "1.6.0",
  "description": "Multi-language Clean Architecture project generator.",
  "type": "module",
  "bin": {
    "arxgen": "dist/bin/arxgen.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "start": "node dist/bin/arxgen.js",
    "dev": "tsx bin/arxgen.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "test:e2e": "npm run build && node -e \"process.env.ARXGEN_RUN_GENERATED_E2E='1'; import('node:child_process').then(({spawnSync})=>{const r=spawnSync(process.execPath,['--test','tests/express-generated-app.test.mjs'],{stdio:'inherit',env:process.env}); process.exit(r.status ?? 1);})\"",
    "test:e2e:postgres": "npm run build && node -e \"process.env.ARXGEN_RUN_POSTGRES_E2E='1'; import('node:child_process').then(({spawnSync})=>{const r=spawnSync(process.execPath,['--test','tests/express-prisma-postgres-e2e.test.mjs'],{stdio:'inherit',env:process.env}); process.exit(r.status ?? 1);})\"",
    "test:e2e:nestjs": "npm run build && node -e \"process.env.ARXGEN_RUN_NESTJS_E2E='1'; import('node:child_process').then(({spawnSync})=>{const r=spawnSync(process.execPath,['--test','tests/nestjs-generated-app.test.mjs'],{stdio:'inherit',env:process.env}); process.exit(r.status ?? 1);})\"",
    "security:audit": "npm audit --audit-level=moderate",
    "security:snyk": "snyk test",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "files": [
    "dist",
    "templates",
    "examples",
    "docs",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SECURITY.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minhbddeveloper-jpg/arxgen_architecture.git"
  },
  "bugs": {
    "url": "https://github.com/minhbddeveloper-jpg/arxgen_architecture/issues"
  },
  "homepage": "https://github.com/minhbddeveloper-jpg/arxgen_architecture#readme",
  "keywords": [
    "clean-architecture",
    "architecture-generator",
    "typescript",
    "express",
    "nestjs",
    "backend",
    "cli",
    "code-generator",
    "scaffolding",
    "prisma"
  ],
  "license": "MIT",
  "dependencies": {
    "handlebars": "^4.7.8",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  },
  "engines": {
    "node": ">=20"
  }
}
