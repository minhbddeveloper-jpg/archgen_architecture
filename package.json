{
  "name": "arxgen",
  "version": "1.1.0",
  "description": "Multi-language Clean Architecture project generator.",
  "type": "module",
  "bin": {
    "arxgen": "dist/bin/arxgen.js"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "npm run clean && tsc",
    "start": "node dist/bin/arxgen.js",
    "dev": "tsx bin/arxgen.ts",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && node --test tests/*.test.mjs",
    "prepublishOnly": "npm run typecheck && npm test"
  },
  "files": [
    "dist",
    "templates",
    "examples",
    "docs",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/minhbddeveloper-jpg/archgen_architecture.git"
  },
  "license": "MIT",
  "dependencies": {
    "handlebars": "^4.7.8",
    "ts-morph": "^23.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "tsx": "^4.7.1",
    "typescript": "^5.4.2"
  },
  "engines": {
    "node": ">=20"
  }
}
