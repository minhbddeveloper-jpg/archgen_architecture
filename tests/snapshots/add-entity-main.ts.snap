import express from "express";
import { createStudentRouter } from "./presentation/routes/studentRoutes.js";

const app = express();
const port = Number(process.env.PORT ?? 3000);

app.use(express.json());

app.get("/health", (_request, response) => {
  response.json({ status: "ok", service: "school-api" });
});
app.use("/students", createStudentRouter());


app.listen(port, () => {
  console.log(`school-api listening on port ${port}`);
});
